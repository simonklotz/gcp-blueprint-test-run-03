rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: any signed-in user may read any profile (needed to show
    // display names). Users may only create/update their own doc.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
    }

    // Projects: only members (or the owner) can read. Only the owner
    // can update or delete. Any signed-in user may create.
    match /projects/{projectId} {
      allow read: if request.auth != null &&
        (request.auth.uid in resource.data.memberIds ||
         request.auth.uid == resource.data.ownerId);
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.ownerId;
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.ownerId;

      // Tasks: project members (or owner) can CRUD.
      match /tasks/{taskId} {
        allow read, write: if request.auth != null &&
          (request.auth.uid in
             get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds ||
           request.auth.uid ==
             get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId);
      }

      // Activity log: members can read, only Cloud Functions (Admin SDK) write.
      match /activityLog/{logId} {
        allow read: if request.auth != null &&
          (request.auth.uid in
             get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds ||
           request.auth.uid ==
             get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId);
        allow write: if false;
      }
    }
  }
}
